# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Used by docker-compose for the postgres container
POSTGRES_USER=tmuser
POSTGRES_PASSWORD=tmpassword
POSTGRES_DB=taskmanagement

# Used by Prisma — must match the values above
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://tmuser:tmpassword@localhost:5432/taskmanagement?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=tmredis
# Used by the app to connect to Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-this-to-a-very-long-random-secret-min-64-chars
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=change-this-to-another-very-long-random-secret-min-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# ─── Swagger ──────────────────────────────────────────────────────────────────
# Set to 'false' in production if you don't want public API docs
SWAGGER_ENABLED=true

